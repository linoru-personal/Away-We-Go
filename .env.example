# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Resend – required for sending trip invitation emails
RESEND_API_KEY=
RESEND_FROM=

# Optional: base URL for invite links. In local dev, add this so invite emails work:
# NEXT_PUBLIC_APP_URL=http://localhost:3000
# (If unset in development, the API falls back to http://localhost:3000.)
